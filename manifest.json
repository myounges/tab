{
  "manifest_version": 3,
  "name": "Tab Archiver",
  "version": "1.1.0",
  "description": "Archive open tabs (excluding pinned) and browse/search them later.",
  "permissions": [
    "tabs",
    "storage",
    "favicon",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tab Archiver"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon.png"
  }
}
